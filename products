{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Product price"
    },
    "image": {
      "type": "string",
      "description": "Product image URL"
    },
    "category": {
      "type": "string",
      "enum": [
        "apparel",
        "accessories",
        "collectibles"
      ],
      "description": "Product category"
    },
    "in_stock": {
      "type": "boolean",
      "default": true
    },
    "members_only": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "price"
  ]
}